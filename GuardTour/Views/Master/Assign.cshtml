@{
    ViewData["Title"] = "BeatAssignMaster";
    Layout = "~/Views/Shared/_LayoutDashboard.cshtml";
}

<style>
    .select2-container--default .select2-selection--single {
        padding: 0rem 0rem !important;
    }

        .select2-container--default .select2-selection--single .select2-selection__arrow {
            top: -8px !important;
        }
</style>

<!-- partial -->
<div class="main-panel main-panel-one" style="width:100% !important">
    <div class="content-wrapper pt-0">
        <div class="row">
            <div class="col-sm-12">
                <div class="home-tab">
                    <div class="tab-content tab-content-basic pt-0">
                        <div class="tab-pane fade show active" id="overview" role="tabpanel" aria-labelledby="overview">
                            <div class="row">
                                <div class="col-lg-12 d-flex flex-column">
                                    <div class="row flex-grow">
                                        <div class="col-12 grid-margin stretch-card">
                                            <div class="card card-rounded">
                                                <div class="card-body">

                                                    <input type="hidden" id="flgmode" value="Add" />
                                                    <input type="hidden" id="txtHiddenId" value="0" />
                                                    <input type="hidden" id="Hid_BeatId" value="0" />
                                                    <div class="d-sm-flex justify-content-between align-items-start">
                                                        <div>
                                                            <h4 class="card-title card-title-dash">
                                                                Master / <a href="#">
                                                                    Beat Assign
                                                                </a>
                                                            </h4>
                                                        </div>
                                                    </div>
                                                    <br>
                                                    <div class="row">

                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Customer Name</label>
                                                                <select name="Customer Name" class="form-control mandatory" id="custid"   onchange="bindsiteid(this.value,0)" style="border: 1px solid lightgray;">
                                                                    <option value="0">Select</option>
                                                                    @if (ViewBag.cust != null)
                                                                    {
                                                                        foreach (var item in ViewBag.cust as List<SelectListItem>)
                                                                        {
                                                                            <option value="@item.Value">@item.Text</option>
                                                                        }
                                                                    }
                                                                </select>

                                                            </div>
                                                        </div>


                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Site Name</label>
                                                                <select name="Site Name" onchange="bindsitet(this.value,0),bindroute(this.value,0)" @* onchange="bindsitet(this.value,0)" *@ class="form-control mandatory" id="siteid" style="border: 1px solid lightgray;">
                                                                    <option value="0">Select</option>
                                                                    @if (ViewBag.site != null)
                                                                    {
                                                                        foreach (var item in ViewBag.site as List<SelectListItem>)
                                                                        {
                                                                            <option value="@item.Value">@item.Text</option>
                                                                        }
                                                                    }
                                                                </select>

                                                            </div>
                                                        </div>




                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Beat Name</label>
                                                                <select name="Beat Name" class="form-control mandatory" style="border: 1px solid lightgray;" id="beatid">
                                                                     <option value="0">Select</option>
                                                                    @* @if (ViewBag.Emp != null)
                                                                    {
                                                                    foreach (var item in ViewBag.Emp as List<SelectListItem>)
                                                                    {
                                                                    <option value="@item.Value">@item.Text</option>
                                                                    }
                                                                    } *@
                                                                </select>

                                                            </div>
                                                        </div>


                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Route Name</label>
                                                                <select name="Route Name" class="form-control mandatory" style="border: 1px solid lightgray;" id="routeid" @* onchange="bindsitet(this.value)" *@>
                                                                    <option value="0">Select</option>
                                                                    @* @if (ViewBag.shift != null)
                                                                    {
                                                                        foreach (var item in ViewBag.shift as List<SelectListItem>)
                                                                        {
                                                                            <option value="@item.Value">@item.Text</option>
                                                                        }
                                                                    } *@
                                                                </select>

                                                            </div>
                                                        </div>
                                                        <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Shift Name</label>
                                                                <select name="Shift Name" class="form-control mandatory" style="border: 1px solid lightgray;" id="siftid" @* onchange="bindsitet(this.value)" *@>
                                                                    <option value="0">Select</option>
                                                                    @if (ViewBag.shift != null)
                                                                    {
                                                                        foreach (var item in ViewBag.shift as List<SelectListItem>)
                                                                        {
                                                                            <option value="@item.Value">@item.Text</option>
                                                                        }
                                                                    }
                                                                </select>

                                                            </div>
                                                        </div>

                                                  

                                                        


                                                        

                                                     @*    <div class="col-md-4">
                                                            <div class="form-group">
                                                                <label>Beat Route Code</label>
                                                                <input type="text" id="routecode" name="Beat Route Code" class="form-control mandatory" />

                                                            </div>
                                                        </div>
                                                        <div class="col-md-4" >
                                                            <div class="form-group">
                                                                <label>Beat Route Name</label>
                                                                <input type="text" id="routeid" name="Beat Route Name" class="form-control mandatory" />

                                                            </div>
                                                        </div> *@

                                                        <div class="col-md-1" style="margin-top: 37px;">
                                                            <div class="form-group">
                                                                <label>Status</label>
                                                                <input type="checkbox" id="status" checked aria-label="Checkbox for following text input">

                                                            </div>
                                                        </div>
                                                        <div class="col-md-3" style="margin-top: 37px;">
                                                            <button onclick="Updateall()" id="submitbtn" class="btn btn-success">
                                                                Save
                                                            </button>
                                                            <a href="/Admin/DashboardLogin">
                                                                <button id="backtbtn" class="btn btn-success">Back</button>
                                                            </a>
                                                        </div>

                                                        <div class="col-md-12">
                                                            <div class="table-data">
                                                                <div id="printdiv"></div>
                                                            </div>
                                                        </div>

                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>
<!-- main-panel ends -->

<script src="~/js/Master/BeatAssign.js"></script>
<script src="~/js/InsAjax.js"></script>
<script src="~/js/Master.js"></script>


<script type="text/javascript" charset="utf8" src="https://code.jquery.com/jquery-3.5.1.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
