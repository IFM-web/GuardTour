                }

   
        body {
            font-family: Arial, sans-serif;
            background-color: #f5f5f5;
        }

        

        

            

          
        button {
            border-radius: 5px;
            padding: 4px;
        }

        * {
            margin: 0;
           /*  padding: 4px; */
            box-sizing: border-box;
        }
           

                


      

        .myContainer{
            display: flex;
            justify-content: space-around;
            padding:10px;
            background-color: #C62828;
            
        }

        .refresh {
            display: flex;
            align-items: center;
            background: white;
            padding: 8px 12px;
            border-radius: 10px;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
            color: black;
            font-weight: bold;
        }

        .refresh-icon {
            margin-right: 5px;
        }

        .switch {
            position: relative;
            width: 34px;
            height: 18px;
            margin-left: 5px;
        }

            .switch input {
                opacity: 0;
                width: 0;
                height: 0;
            }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #ccc;
            border-radius: 34px;
            transition: 0.4s;
        }

            .slider:before {
                content: "";
                position: absolute;
                height: 14px;
                width: 14px;
                left: 2px;
                bottom: 2px;
                background: white;
                border-radius: 50%;
                transition: 0.4s;
            }

        input:checked + .slider {
            background: #4CAF50;
        }

            input:checked + .slider:before {
                transform: translateX(16px);
            }


        .dropdown-container {
            background-color: #ffffff;
            border: none;
            padding: 0px 0px;
            border-radius: 5px;
            color: #333;
            margin-left: 10px;
            font-size: 14px;
            width: 20%;
        }

        
        select {
           
            font-size: 14px;
            padding: 5px;
            width: 220%;
            background: white;
            color: black;
        }

        .next-btn {
            
            margin-top: 55px;
            position: fixed;
           /*  top: 33%; */
            right: 10px; 
            transform: translateY(-50%);
            background: #f5f5f5;
            border: none;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
            cursor: pointer;
        }

            .next-btn svg {
                width: 30px;
                height: 30px;
                fill: gray;
                transform: rotate(180deg);
            }


        .prev-btn {
            margin-top: 55px;
            position: fixed;
            /* top: 33%; */
            left: 10px; /* Adjust this for spacing */
            transform: translateY(-50%);
            background: #f5f5f5;
            border: none;
            border-radius: 50%;
            width: 50px;
            height: 50px;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.2);
            cursor: pointer;
        }

            .prev-btn svg {
                width: 30px;
                height: 30px;
                fill: gray;
            }

        .container1 {
            display: flex;
            gap: 10px;
            margin-inline-start: 80px;
            margin-bottom: -30px;
            margin-top: -30px;
        }

        .card {
            
            width: 190px;
            padding: 10px;
            text-align: center;
            border: 1px solid #ddd;
            border-radius: 5px;
            background: white;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .title {
            font-size: 14px;
            font-weight: bold;
            margin: 0;
            color: black;
        }

        .count {
