                    padding: 5px 10px;
                    border-radius: 5px;
                    color: #333;
                    margin-left: 10px;
                    font-size: 14px;
                }

        


            .navbar .user-info {
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .navbar .user-info img {
