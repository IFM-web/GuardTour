            margin: 0;
            color: black;
        }

            .count span {
                color: green;
                font-weight: bold;
            }


        .container-fluid {
            padding-top: 10px;
            padding-left: 60px;
            padding-right: 60px;
            background:black
        }

        .panel {
            padding: 15px;
            border: 1px solid black;
            border-radius: 10px;
            background-color: #000000;
            overflow: auto;
            color: white;
        }

       
        .btn-custom {
            background-color: #c23136;
            color: white;
            /* border: none; */
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-custom1 {
            background-color: white;
            color: black;
           /*  border: none; */
            padding: 5px 10px;
            border-radius: 5px;
            cursor: pointer;
        }
        .chart-container {
            text-align: center;
            padding: 20px;
            display: flex;
            justify-content: flex-end; 
            width: 100%;
        }

    </style>
   
</head>
<body>




