        color: black;
        font-weight: 500;
    }

    }

    .navbar{
        max-width:100%;
    }

    .container{
      max-width:100% !important;
      padding:0 !important;
    }



    .login-size {
        max-width: 500px;
        margin-top: 70px;
    }

    .auth-form-light {
        background-color: #f8f9fa;
        border-radius: 10px;
        padding: 30px;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    }

    .form-text {
        font-size: 14px;
        color: #888;
        margin-top: 5px;
    }

    .form-control-lg {
        border-radius: 5px;
    }

    .btn-primary {
        background-color: #007bff;
        border: none;
        font-size: 16px;
    }

        .btn-primary:hover {
            background-color: #0056b3;
        }










