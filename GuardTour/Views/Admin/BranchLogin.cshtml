        text-align: center;
        max-width: 500px;
        margin: auto;
    }

        .login-container h2 {
            margin-bottom: 20px;
            font-size: 20px;
            color: #333;
        }

        .login-container label {
            display: block;
            margin-bottom: 5px;
            font-weight: bold;
            color: #666;
            text-align: left;
        }

        .login-container select {
            width: 100%;
            padding: 10px;
            margin-bottom: 15px;
            border-radius: 5px;
            border: 1px solid #ccc;
            background-color: #f7f7f7;
        }


        .login-container button {
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
            padding: 10px;
            width: 100%;
            cursor: pointer;
        }

            .login-container button:hover {
                background-color: #45a049;
            }


    body {
        font-family: "Poppins", sans-serif;
    }

    .container-scroller {
