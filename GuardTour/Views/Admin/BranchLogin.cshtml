<nav class="navbar navbar-expand-lg bg-white navbar-light">
    <a href="" class="navbar-brand d-flex align-items-center ps-2">
        <img src="~/img/logo.png" alt="" class="img-fluid" width="140px" />
    </a>
    <button type="button"
            class="navbar-toggler me-4"
            data-bs-toggle="collapse"
            data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ">
            <a href="/Admin/Company" class="nav-item nav-link">
                <div class="d-flex align-items-left gap-1">

                    <strong>Create Company</strong>
                </div>
            </a>
            <a href="/Admin/Branch" class="nav-item nav-link">
                <div class="d-flex align-items-center gap-1">

                    <strong>Create Branch</strong>
                </div>
            </a>
            
        </div>
     
        <a id="btnlogout" type="button" asp-controller="Home" asp-action="Logout"
           style="position: absolute; top: 10px; right: 10px;background-color: #4CAF50; color: white; padding: 6px 20px; border: none; text-decoration: none;">
            Logout
        </a>
    </div>
</nav>


<div class="container-scroller">
    <div class="container-fluid page-body-wrapper full-page-wrapper">
        <div class="content-wrapper d-flex align-items-center auth px-0">
            <div class="row w-100 mx-0">
                <div class="col-lg-4 mx-auto login-size">
                    <div class="auth-form-light text-left p-5" style="width: 489px;">
                        <div class="text-center">
                            <img src="~/img/Logo-Icon.png" class="mb-4" style="max-width: 150px;" alt="Logo">
                            <h2 class="fw-light mb-4">Branch Login</h2>
                        </div>
                        <form method="post">
                            <div class="form-group">
                                <label for="company" class="form-label">Company</label>
                                <select id="company" class="form-control form-control-lg" asp-for="companyid" onchange="bindBranch(this.value)">
                                   @*  <option value="0">Select</option> *@
                                    @if (ViewBag.com != null)
                                    {
                                        foreach (var item in ViewBag.com)
                                        {
                                            <option value="@item.Value">@item.Text</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="form-group mt-4">
                                <label for="branch" class="form-label">Branch</label>
                                <select class="form-control form-control-lg" id="branch" asp-for="branch_id">
                                    @* <option value="0">Select Branch</option> *@
                                </select>
                            </div>

                            <div class="d-flex justify-content-center mt-5">
                                <button type="submit" id="continue" class="btn btn-primary btn-lg w-100" style="background-color: #4CAF50; color: white;">
                                    Continue
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.7.1.js" integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4=" crossorigin="anonymous"></script>

@* <script src="~/grouplreportingportal/js/Reports/BranchLogin.js"></script> *@
<script src="~/js/Admin/BranchLogin.js"></script>


<script>

    var message = '@ViewBag.message';
    if (message)
        alert(message)
</script>


